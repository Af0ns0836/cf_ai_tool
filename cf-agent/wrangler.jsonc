{
  "name": "my-agent",
  "main": "src/server.ts",
  // Set this to today's date
  "compatibility_date": "2026-04-27",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "CounterAgent",
        "class_name": "CounterAgent",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CounterAgent"],
    },
  ],
  "ai": {
	"binding": "AI",
  }
}